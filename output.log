        for k in range(0, 32):  // reduction
          acc[0] = (acc[0] + (A[i, k] * W_local[j_inner, k]))
        acc[0] = (acc[0] + B[0, ((j_outer * 32) + j_inner)])
        Out[i, ((j_outer * 32) + j_inner)] = max(acc[0], 0)
