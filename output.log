    for j in range(0, 8):
      acc[0] = 0
      for k in range(0, 64):  // reduction
        acc[0] = (acc[0] + (A[i, k] * W[j, k]))
      acc[0] = (acc[0] + B[0, j])
      Out[i, j] = acc[0]
}


