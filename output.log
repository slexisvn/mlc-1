@fused_dense_bias_relu(A: Buffer[1,32], W: Buffer[64,32], B: Buffer[1,64], Out: Buffer[1,64]) {
  alloc acc: float32[1]  scope=local
  for i in range(0, 1):
    for j in range(0, 64):
      acc[0] = 0
      for k in range(0, 32):  // reduction
        acc[0] = (acc[0] + (A[i, k] * W[j, k]))
      acc[0] = (acc[0] + B[0, j])
      Out[i, j] = max(acc[0], 0)
}

@fused_dense_bias(A: Buffer[1,64], W: Buffer[8,64], B: Buffer[1,8], Out: Buffer[1,8]) {
  alloc acc: float32[1]  scope=local
  for i in range(0, 1):
    for j in range(0, 8):
      acc[0] = 0
      for k in range(0, 64):  // reduction
        acc[0] = (acc[0] + (A[i, k] * W[j, k]))
      acc[0] = (acc[0] + B[0, j])
      Out[i, j] = acc[0]
}


