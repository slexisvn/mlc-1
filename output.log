  //     Out      byte  13088– 13215 (128B)

(module
  ;; Linear memory: 1 page(s) = 64KB
  (memory (export "memory") 1)

    ;; ─── fused_dense_bias_relu ───
    ;; Inputs: A[4,32], W[64,32], B[1,64], Out[4,64]
    (func $fused_dense_bias_relu (export "fused_dense_bias_relu") (param $A i32) (param $W i32) (param $B i32) (param $Out i32)
    (local $i i32)
    (local $j i32)
    (local $k i32)
    (local $acc f32)
    
    ;; for i in [0, 4)
    i32.const 0
    local.set $i
    block $L0
      loop $L1
        local.get $i
        i32.const 4
        i32.ge_s
        br_if $L0
        ;; for j in [0, 64)
        i32.const 0
        local.set $j
        block $L2
          loop $L3
            local.get $j
            i32.const 64
            i32.ge_s
            br_if $L2
            ;; scalar $acc = ...
            f32.const 0
            local.set $acc
            ;; for k in [0, 32)
            i32.const 0
            local.set $k
            block $L4
              loop $L5
                local.get $k
                i32.const 32
                i32.ge_s
                br_if $L4
                ;; scalar $acc = ...
                ;; scalar load $acc
                local.get $acc
                ;; load A[...]
                local.get $A
                local.get $i
                i32.const 32
                i32.mul
                local.get $k
                i32.const 1
                i32.mul
                i32.add
                i32.const 4
                i32.mul
                i32.add
                f32.load
                ;; load W[...]
                local.get $W
                local.get $j
                i32.const 32
                i32.mul
                local.get $k
                i32.const 1
                i32.mul
                i32.add
                i32.const 4
                i32.mul
                i32.add
                f32.load
                f32.mul
                f32.add
                local.set $acc
                local.get $k
                i32.const 1
                i32.add
                local.set $k
                br $L5
              end ;; loop $L5
            end ;; block $L4
            ;; scalar $acc = ...
            ;; scalar load $acc
            local.get $acc
            ;; load B[...]
            local.get $B
            i32.const 0
            i32.const 64
            i32.mul
            local.get $j
            i32.const 1
            i32.mul
            i32.add
            i32.const 4
            i32.mul
            i32.add
            f32.load
            f32.add
            local.set $acc
            ;; store Out[...]
            local.get $Out
            local.get $i
            i32.const 64
            i32.mul
            local.get $j
            i32.const 1
            i32.mul
            i32.add
            i32.const 4
            i32.mul
            i32.add
            ;; scalar load $acc
            local.get $acc
            f32.const 0
            f32.max
            f32.store
            local.get $j
            i32.const 1
            i32.add
            local.set $j
            br $L3
          end ;; loop $L3
        end ;; block $L2
        local.get $i
        i32.const 1
        i32.add
        local.set $i
        br $L1
      end ;; loop $L1
    end ;; block $L0
    )

    ;; ─── fused_dense_bias ───
    ;; Inputs: A[4,64], W[8,64], B[1,8], Out[4,8]
    (func $fused_dense_bias (export "fused_dense_bias") (param $A i32) (param $W i32) (param $B i32) (param $Out i32)
    (local $i i32)
    (local $j i32)
    (local $k i32)
    (local $acc f32)
    
    ;; for i in [0, 4)
    i32.const 0
    local.set $i
    block $L0
      loop $L1
        local.get $i
        i32.const 4
        i32.ge_s
        br_if $L0
        ;; for j in [0, 8)
        i32.const 0
        local.set $j
        block $L2
          loop $L3
            local.get $j
            i32.const 8
            i32.ge_s
            br_if $L2
            ;; scalar $acc = ...
            f32.const 0
            local.set $acc
            ;; for k in [0, 64)
            i32.const 0
            local.set $k
            block $L4
              loop $L5
                local.get $k
                i32.const 64
                i32.ge_s
                br_if $L4
                ;; scalar $acc = ...
                ;; scalar load $acc
                local.get $acc
                ;; load A[...]
                local.get $A
                local.get $i
                i32.const 64
                i32.mul
                local.get $k
                i32.const 1
                i32.mul
                i32.add
                i32.const 4
                i32.mul
                i32.add
                f32.load
                ;; load W[...]
                local.get $W
                local.get $j
                i32.const 64
                i32.mul
                local.get $k
                i32.const 1
                i32.mul
                i32.add
                i32.const 4
                i32.mul
                i32.add
                f32.load
                f32.mul
                f32.add
                local.set $acc
                local.get $k
                i32.const 1
                i32.add
                local.set $k
                br $L5
              end ;; loop $L5
            end ;; block $L4
            ;; scalar $acc = ...
            ;; scalar load $acc
            local.get $acc
            ;; load B[...]
            local.get $B
            i32.const 0
            i32.const 8
            i32.mul
            local.get $j
            i32.const 1
            i32.mul
            i32.add
            i32.const 4
            i32.mul
            i32.add
            f32.load
            f32.add
            local.set $acc
            ;; store Out[...]
            local.get $Out
            local.get $i
            i32.const 8
            i32.mul
            local.get $j
            i32.const 1
            i32.mul
            i32.add
            i32.const 4
            i32.mul
            i32.add
            ;; scalar load $acc
            local.get $acc
            f32.store
            local.get $j
            i32.const 1
            i32.add
            local.set $j
            br $L3
          end ;; loop $L3
        end ;; block $L2
        local.get $i
        i32.const 1
        i32.add
        local.set $i
        br $L1
      end ;; loop $L1
    end ;; block $L0
    )

)

