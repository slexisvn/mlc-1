@main(%x: Tensor[(1, 784), float32], %target: Tensor[(1), float32]) → Tensor[(1), float32] {
  %0 = nn.dense(%x, meta[param_0])  // [1,256]
  %1 = nn.bias_add(%0, meta[param_1])  // [1,256]
  %2 = nn.relu(%1)  // [1,256]
  %3 = nn.dense(%2, meta[param_2])  // [1,10]
  %4 = nn.bias_add(%3, meta[param_3])  // [1,10]
  %5 = cross_entropy(%4, %target)  // [1]
}


