      Out[i * 20 + j] = acc[0];
    }
  }
}


── Scheduled (optimized) code ──
function fused_dense_bias_sigmoid(A, W, B, Out) {
  // Buffer shapes:
  // A: [1, 784] (global)
  // W: [256, 784] (global)
  // B: [1, 256] (global)
  // Out: [1, 256] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 1; i++) {
    for (let j_outer = 0; j_outer < 8; j_outer++) { /* parallel */
      for (let j_inner = 0; j_inner < 32; j_inner++) {
        acc[0] = 0;
        for (let k_outer = 0; k_outer < 14; k_outer++) {
          for (let k_inner = 0; k_inner < 56; k_inner++) {
            acc[0] = (acc[0] + (A[i * 784 + ((k_outer * 56) + k_inner)] * W[((j_outer * 32) + j_inner) * 784 + ((k_outer * 56) + k_inner)]));
          }
        }
        acc[0] = (acc[0] + B[0 * 256 + ((j_outer * 32) + j_inner)]);
        Out[i * 256 + ((j_outer * 32) + j_inner)] = (1 / (1 + Math.exp((0 - acc[0]))));
      }
    }
  }
}

function fused_dense_bias(A, W, B, Out) {
  // Buffer shapes:
  // A: [1, 256] (global)
  // W: [20, 256] (global)
  // B: [1, 20] (global)
  // Out: [1, 20] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 1; i++) {
    for (let j = 0; j < 20; j++) {
      acc[0] = 0;
      for (let k = 0; k < 256; k++) {
        acc[0] = (acc[0] + (A[i * 256 + k] * W[j * 256 + k]));
      }
      acc[0] = (acc[0] + B[0 * 20 + j]);
      Out[i * 20 + j] = acc[0];
    }
  }
}


