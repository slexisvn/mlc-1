── Naive (unoptimized) code ──
function fused_dense_bias_relu(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 32] (global)
  // W: [64, 32] (global)
  // B: [1, 64] (global)
  // Out: [4, 64] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 4; i++) {
    for (let j = 0; j < 64; j++) {
      acc[0] = 0;
      for (let k = 0; k < 32; k++) {
        acc[0] = (acc[0] + (A[i * 32 + k] * W[j * 32 + k]));
      }
      acc[0] = (acc[0] + B[0 * 64 + j]);
      Out[i * 64 + j] = Math.max(acc[0], 0);
    }
  }
}

function fused_dense_bias(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 64] (global)
  // W: [1, 64] (global)
  // B: [1, 1] (global)
  // Out: [4, 1] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 4; i++) {
    for (let j = 0; j < 1; j++) {
      acc[0] = 0;
      for (let k = 0; k < 64; k++) {
        acc[0] = (acc[0] + (A[i * 64 + k] * W[j * 64 + k]));
      }
      acc[0] = (acc[0] + B[0 + j]);
      Out[i + j] = acc[0];
    }
  }
}


