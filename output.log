── Naive (unoptimized) code ──
function fused_dense_bias_relu(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 32] (global)
  // W: [64, 32] (global)
  // B: [1, 64] (global)
  // Out: [4, 64] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 4; i++) {
    for (let j = 0; j < 64; j++) {
      acc[0] = 0;
      for (let k = 0; k < 32; k++) {
        acc[0] = (acc[0] + (A[i * 32 + k] * W[j * 32 + k]));
      }
      acc[0] = (acc[0] + B[0 * 64 + j]);
      Out[i * 64 + j] = Math.max(acc[0], 0);
    }
  }
}

function fused_dense_bias(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 64] (global)
  // W: [1, 64] (global)
  // B: [1, 1] (global)
  // Out: [4, 1] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 4; i++) {
    for (let j = 0; j < 1; j++) {
      acc[0] = 0;
      for (let k = 0; k < 64; k++) {
        acc[0] = (acc[0] + (A[i * 64 + k] * W[j * 64 + k]));
      }
      acc[0] = (acc[0] + B[0 + j]);
      Out[i + j] = acc[0];
    }
  }
}


── Scheduled + Optimized code (tuner-selected schedule) ──
function fused_dense_bias_relu_packed(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 32] (global)
  // W: [64, 32] (global)
  // B: [1, 64] (global)
  // Out: [4, 64] (global)
  
  const W_packed = new Float32Array(2048); // local
  let acc = 0; // scalar (promoted from buffer)
  
  for (let _jo_pack = 0; _jo_pack < 4; _jo_pack++) {
    for (let _kl_pack = 0; _kl_pack < 32; _kl_pack++) {
      for (let _ji_pack = 0; _ji_pack < 16; _ji_pack++) {
        W_packed[_jo_pack * 512 + _kl_pack * 16 + _ji_pack] = W[((_jo_pack * 16) + _ji_pack) * 32 + _kl_pack];
      }
    }
  }
  for (let i_outer = 0; i_outer < 2; i_outer++) {
    for (let j_outer = 0; j_outer < 2; j_outer++) {
      for (let i_inner = 0; i_inner < 2; i_inner++) {
        for (let j_inner = 0; j_inner < 32; j_inner++) {
          acc = 0;
          for (let k_outer = 0; k_outer < 8; k_outer++) {
            for (let k_inner = 0; k_inner < 4; k_inner++) {
              acc = (acc + (A[((i_outer * 2) + i_inner) * 32 + ((k_outer * 4) + k_inner)] * W_packed[Math.floor(((j_outer * 32) + j_inner) / 16) * 512 + ((k_outer * 4) + k_inner) * 16 + (((j_outer * 32) + j_inner) % 16)]));
            }
          }
          acc = (acc + B[0 * 64 + ((j_outer * 32) + j_inner)]);
          Out[((i_outer * 2) + i_inner) * 64 + ((j_outer * 32) + j_inner)] = Math.max(acc, 0);
        }
      }
    }
  }
}

function fused_dense_bias(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 64] (global)
  // W: [1, 64] (global)
  // B: [1, 1] (global)
  // Out: [4, 1] (global)
  
  let acc = 0; // scalar (promoted from buffer)
  
  for (let i = 0; i < 4; i++) {
    for (let j_outer = 0; j_outer < 1; j_outer++) {
      // unrolled loop j_inner (1 iterations)
      { const j_inner = 0;
        acc = 0;
        for (let k_outer = 0; k_outer < 16; k_outer++) {
          for (let k_inner = 0; k_inner < 4; k_inner++) {
            acc = (acc + (A[i * 64 + ((k_outer * 4) + k_inner)] * W[(j_outer + j_inner) * 64 + ((k_outer * 4) + k_inner)]));
          }
        }
        acc = (acc + B[0 + (j_outer + j_inner)]);
        Out[i + (j_outer + j_inner)] = acc;
      }
    }
  }
}


── 8.2 Register-Tiled code (4-way accumulator) ──
function fused_dense_bias_relu_reg4(A, W, B, Out) {
  // Register-tiled: 4-way accumulator unrolling
  // Loads A[k] once, reuses for 4 output elements → 4× fewer A reads
  for (let i = 0; i < 4; i++) {
    for (let j = 0; j < 64; j += 4) {
      let acc0 = 0, acc1 = 0, acc2 = 0, acc3 = 0;
      for (let k = 0; k < 32; k++) {
        const a = A[i * 32 + k]; // load once, reuse 4x
        acc0 += a * W[(j + 0) * 32 + k];
        acc1 += a * W[(j + 1) * 32 + k];
        acc2 += a * W[(j + 2) * 32 + k];
        acc3 += a * W[(j + 3) * 32 + k];
      }
      acc0 += B[j + 0];
      acc1 += B[j + 1];
      acc2 += B[j + 2];
      acc3 += B[j + 3];
      Out[i * 64 + j + 0] = Math.max(acc0, 0);
      Out[i * 64 + j + 1] = Math.max(acc1, 0);
      Out[i * 64 + j + 2] = Math.max(acc2, 0);
      Out[i * 64 + j + 3] = Math.max(acc3, 0);
    }
  }
}


── 8.3 F9 Vectorized code (SIMD width=4) ──
  // Vectorized loops: j → split to j_outer × j_inner[4]
function fused_dense_bias_relu(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 32] (global)
  // W: [64, 32] (global)
  // B: [1, 64] (global)
  // Out: [4, 64] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 4; i++) {
    for (let j_outer = 0; j_outer < 16; j_outer++) {
      // vectorize: 4 SIMD lanes (j_inner = 0..3)
      { const j_inner = 0;
        acc[0] = 0;
        for (let k = 0; k < 32; k++) {
          acc[0] = (acc[0] + (A[i * 32 + k] * W[((j_outer * 4) + j_inner) * 32 + k]));
        }
        acc[0] = (acc[0] + B[0 * 64 + ((j_outer * 4) + j_inner)]);
        Out[i * 64 + ((j_outer * 4) + j_inner)] = Math.max(acc[0], 0);
      }
      { const j_inner = 1;
        acc[0] = 0;
        for (let k = 0; k < 32; k++) {
          acc[0] = (acc[0] + (A[i * 32 + k] * W[((j_outer * 4) + j_inner) * 32 + k]));
        }
        acc[0] = (acc[0] + B[0 * 64 + ((j_outer * 4) + j_inner)]);
        Out[i * 64 + ((j_outer * 4) + j_inner)] = Math.max(acc[0], 0);
      }
      { const j_inner = 2;
        acc[0] = 0;
        for (let k = 0; k < 32; k++) {
          acc[0] = (acc[0] + (A[i * 32 + k] * W[((j_outer * 4) + j_inner) * 32 + k]));
        }
        acc[0] = (acc[0] + B[0 * 64 + ((j_outer * 4) + j_inner)]);
        Out[i * 64 + ((j_outer * 4) + j_inner)] = Math.max(acc[0], 0);
      }
      { const j_inner = 3;
        acc[0] = 0;
        for (let k = 0; k < 32; k++) {
          acc[0] = (acc[0] + (A[i * 32 + k] * W[((j_outer * 4) + j_inner) * 32 + k]));
        }
        acc[0] = (acc[0] + B[0 * 64 + ((j_outer * 4) + j_inner)]);
        Out[i * 64 + ((j_outer * 4) + j_inner)] = Math.max(acc[0], 0);
      }
    }
  }
}

