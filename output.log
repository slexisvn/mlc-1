  Phase 5: Schedule Transformations
════════════════════════════════════════════════════════════
  Scheduling fused_dense_bias_relu:
    split(j, 32) → j_outer, j_inner
    split(k, 56) → k_outer, k_inner
    reorder(j_outer, k_outer, j_inner, k_inner)
    parallel(j_outer)
  fused_dense_bias: no tiling (loops too small or absent)

  Scheduled TIR:
@fused_dense_bias_relu(A: Buffer[1,784], W: Buffer[256,784], B: Buffer[1,256], Out: Buffer[1,256]) {
  alloc acc: float32[1]  scope=local
  for i in range(0, 1):
    for j_outer in range(0, 8):  // parallel
      for j_inner in range(0, 32):
        acc[0] = 0
        for k_outer in range(0, 14):  // reduction
          for k_inner in range(0, 56):  // reduction
            acc[0] = (acc[0] + (A[i, ((k_outer * 56) + k_inner)] * W[((j_outer * 32) + j_inner), ((k_outer * 56) + k_inner)]))
        acc[0] = (acc[0] + B[0, ((j_outer * 32) + j_inner)])
        Out[i, ((j_outer * 32) + j_inner)] = max(acc[0], 0)
}

@fused_dense_bias(A: Buffer[1,256], W: Buffer[10,256], B: Buffer[1,10], Out: Buffer[1,10]) {
  alloc acc: float32[1]  scope=local
  for i in range(0, 1):
    for j in range(0, 10):
      acc[0] = 0
      for k in range(0, 256):  // reduction
        acc[0] = (acc[0] + (A[i, k] * W[j, k]))
      acc[0] = (acc[0] + B[0, j])
      Out[i, j] = acc[0]
}


