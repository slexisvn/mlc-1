── Naive (unoptimized) code ──
function fused_dense_bias_relu(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 32] (global)
  // W: [64, 32] (global)
  // B: [1, 64] (global)
  // Out: [4, 64] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 4; i++) {
    for (let j = 0; j < 64; j++) {
      acc[0] = 0;
      for (let k = 0; k < 32; k++) {
        acc[0] = (acc[0] + (A[i * 32 + k] * W[j * 32 + k]));
      }
      acc[0] = (acc[0] + B[0 * 64 + j]);
      Out[i * 64 + j] = Math.max(acc[0], 0);
    }
  }
}

function fused_dense_bias(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 64] (global)
  // W: [8, 64] (global)
  // B: [1, 8] (global)
  // Out: [4, 8] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 4; i++) {
    for (let j = 0; j < 8; j++) {
      acc[0] = 0;
      for (let k = 0; k < 64; k++) {
        acc[0] = (acc[0] + (A[i * 64 + k] * W[j * 64 + k]));
      }
      acc[0] = (acc[0] + B[0 * 8 + j]);
      Out[i * 8 + j] = acc[0];
    }
  }
}


── Scheduled + Optimized code (tuner-selected schedule) ──
function fused_dense_bias_relu(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 32] (global)
  // W: [64, 32] (global)
  // B: [1, 64] (global)
  // Out: [4, 64] (global)
  
  let acc = 0; // scalar (promoted from buffer)
  
  for (let i_outer = 0; i_outer < 2; i_outer++) {
    for (let j_outer = 0; j_outer < 8; j_outer++) {
      for (let i_inner = 0; i_inner < 2; i_inner++) {
        // unrolled loop j_inner (8 iterations)
        { const j_inner = 0;
          acc = 0;
          for (let k_outer = 0; k_outer < 8; k_outer++) {
            for (let k_inner = 0; k_inner < 4; k_inner++) {
              acc = (acc + (A[((i_outer * 2) + i_inner) * 32 + ((k_outer * 4) + k_inner)] * W[((j_outer * 8) + j_inner) * 32 + ((k_outer * 4) + k_inner)]));
            }
          }
          acc = (acc + B[0 * 64 + ((j_outer * 8) + j_inner)]);
          Out[((i_outer * 2) + i_inner) * 64 + ((j_outer * 8) + j_inner)] = Math.max(acc, 0);
        }
        { const j_inner = 1;
          acc = 0;
          for (let k_outer = 0; k_outer < 8; k_outer++) {
            for (let k_inner = 0; k_inner < 4; k_inner++) {
              acc = (acc + (A[((i_outer * 2) + i_inner) * 32 + ((k_outer * 4) + k_inner)] * W[((j_outer * 8) + j_inner) * 32 + ((k_outer * 4) + k_inner)]));
            }
          }
          acc = (acc + B[0 * 64 + ((j_outer * 8) + j_inner)]);
          Out[((i_outer * 2) + i_inner) * 64 + ((j_outer * 8) + j_inner)] = Math.max(acc, 0);
        }
        { const j_inner = 2;
          acc = 0;
          for (let k_outer = 0; k_outer < 8; k_outer++) {
            for (let k_inner = 0; k_inner < 4; k_inner++) {
              acc = (acc + (A[((i_outer * 2) + i_inner) * 32 + ((k_outer * 4) + k_inner)] * W[((j_outer * 8) + j_inner) * 32 + ((k_outer * 4) + k_inner)]));
            }
          }
          acc = (acc + B[0 * 64 + ((j_outer * 8) + j_inner)]);
          Out[((i_outer * 2) + i_inner) * 64 + ((j_outer * 8) + j_inner)] = Math.max(acc, 0);
        }
        { const j_inner = 3;
          acc = 0;
          for (let k_outer = 0; k_outer < 8; k_outer++) {
            for (let k_inner = 0; k_inner < 4; k_inner++) {
              acc = (acc + (A[((i_outer * 2) + i_inner) * 32 + ((k_outer * 4) + k_inner)] * W[((j_outer * 8) + j_inner) * 32 + ((k_outer * 4) + k_inner)]));
            }
          }
          acc = (acc + B[0 * 64 + ((j_outer * 8) + j_inner)]);
          Out[((i_outer * 2) + i_inner) * 64 + ((j_outer * 8) + j_inner)] = Math.max(acc, 0);
        }
        { const j_inner = 4;
          acc = 0;
          for (let k_outer = 0; k_outer < 8; k_outer++) {
            for (let k_inner = 0; k_inner < 4; k_inner++) {
              acc = (acc + (A[((i_outer * 2) + i_inner) * 32 + ((k_outer * 4) + k_inner)] * W[((j_outer * 8) + j_inner) * 32 + ((k_outer * 4) + k_inner)]));
            }
          }
          acc = (acc + B[0 * 64 + ((j_outer * 8) + j_inner)]);
          Out[((i_outer * 2) + i_inner) * 64 + ((j_outer * 8) + j_inner)] = Math.max(acc, 0);
        }
        { const j_inner = 5;
          acc = 0;
          for (let k_outer = 0; k_outer < 8; k_outer++) {
            for (let k_inner = 0; k_inner < 4; k_inner++) {
              acc = (acc + (A[((i_outer * 2) + i_inner) * 32 + ((k_outer * 4) + k_inner)] * W[((j_outer * 8) + j_inner) * 32 + ((k_outer * 4) + k_inner)]));
            }
          }
          acc = (acc + B[0 * 64 + ((j_outer * 8) + j_inner)]);
          Out[((i_outer * 2) + i_inner) * 64 + ((j_outer * 8) + j_inner)] = Math.max(acc, 0);
        }
        { const j_inner = 6;
          acc = 0;
          for (let k_outer = 0; k_outer < 8; k_outer++) {
            for (let k_inner = 0; k_inner < 4; k_inner++) {
              acc = (acc + (A[((i_outer * 2) + i_inner) * 32 + ((k_outer * 4) + k_inner)] * W[((j_outer * 8) + j_inner) * 32 + ((k_outer * 4) + k_inner)]));
            }
          }
          acc = (acc + B[0 * 64 + ((j_outer * 8) + j_inner)]);
          Out[((i_outer * 2) + i_inner) * 64 + ((j_outer * 8) + j_inner)] = Math.max(acc, 0);
        }
        { const j_inner = 7;
          acc = 0;
          for (let k_outer = 0; k_outer < 8; k_outer++) {
            for (let k_inner = 0; k_inner < 4; k_inner++) {
              acc = (acc + (A[((i_outer * 2) + i_inner) * 32 + ((k_outer * 4) + k_inner)] * W[((j_outer * 8) + j_inner) * 32 + ((k_outer * 4) + k_inner)]));
            }
          }
          acc = (acc + B[0 * 64 + ((j_outer * 8) + j_inner)]);
