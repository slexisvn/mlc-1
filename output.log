  Phase 8: Code Generation (→ JavaScript)
════════════════════════════════════════════════════════════

── Naive (unoptimized) code ──
function fused_dense_bias_relu(A, W, B, Out) {
  // Buffer shapes:
  // A: [1, 32] (global)
  // W: [64, 32] (global)
  // B: [1, 64] (global)
  // Out: [1, 64] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 1; i++) {
    for (let j = 0; j < 64; j++) {
      acc[0] = 0;
      for (let k = 0; k < 32; k++) {
        acc[0] = (acc[0] + (A[i * 32 + k] * W[j * 32 + k]));
      }
      acc[0] = (acc[0] + B[0 * 64 + j]);
      Out[i * 64 + j] = Math.max(acc[0], 0);
    }
  }
}

function fused_dense_bias(A, W, B, Out) {
  // Buffer shapes:
  // A: [1, 64] (global)
  // W: [8, 64] (global)
  // B: [1, 8] (global)
  // Out: [1, 8] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 1; i++) {
    for (let j = 0; j < 8; j++) {
      acc[0] = 0;
      for (let k = 0; k < 64; k++) {
        acc[0] = (acc[0] + (A[i * 64 + k] * W[j * 64 + k]));
      }
      acc[0] = (acc[0] + B[0 * 8 + j]);
      Out[i * 8 + j] = acc[0];
    }
  }
}


── Scheduled + Optimized code ──
function fused_dense_bias_relu(A, W, B, Out) {
  // Buffer shapes:
  // A: [1, 32] (global)
  // W: [64, 32] (global)
  // B: [1, 64] (global)
  // Out: [1, 64] (global)
  
  const W_local = new Float32Array(1024); // local
  let acc = 0; // scalar (promoted from buffer)
  
  for (let i = 0; i < 1; i++) {
    for (let j_outer = 0; j_outer < 2; j_outer++) { /* parallel */
      for (let _jl_cr = 0; _jl_cr < 32; _jl_cr++) {
        for (let _kl_cr = 0; _kl_cr < 32; _kl_cr++) {
          W_local[_jl_cr * 32 + _kl_cr] = W[((j_outer * 32) + _jl_cr) * 32 + _kl_cr];
        }
      }
      for (let j_inner = 0; j_inner < 32; j_inner++) {
        acc = 0;
        for (let k = 0; k < 32; k++) {
          acc = (acc + (A[i * 32 + k] * W[((j_outer * 32) + j_inner) * 32 + k]));
        }
        acc = (acc + B[0 * 64 + ((j_outer * 32) + j_inner)]);
        Out[i * 64 + ((j_outer * 32) + j_inner)] = Math.max(acc, 0);
      }
    }
  }
}

function fused_dense_bias(A, W, B, Out) {
  // Buffer shapes:
  // A: [1, 64] (global)
  // W: [8, 64] (global)
  // B: [1, 8] (global)
  // Out: [1, 8] (global)
  
  let acc = 0; // scalar (promoted from buffer)
  
  for (let i = 0; i < 1; i++) {
    for (let j = 0; j < 8; j++) {
      acc = 0;
      for (let k = 0; k < 64; k++) {
        acc = (acc + (A[i * 64 + k] * W[j * 64 + k]));
      }
      acc = (acc + B[0 * 8 + j]);
      Out[i * 8 + j] = acc;
    }
  }
}


── 8.2 Register-Tiled code (4-way accumulator) ──
function fused_dense_bias_relu_reg4(A, W, B, Out) {
  // Register-tiled: 4-way accumulator unrolling
  // Loads A[k] once, reuses for 4 output elements → 4× fewer A reads
  for (let i = 0; i < 1; i++) {
    for (let j = 0; j < 64; j += 4) {
      let acc0 = acc1 = acc2 = acc3 = 0;
      for (let k = 0; k < 32; k++) {
        const a = A[i * 32 + k]; // load once, reuse 4x
        acc0 += a * W[(j + 0) * 32 + k];
        acc1 += a * W[(j + 1) * 32 + k];
        acc2 += a * W[(j + 2) * 32 + k];
        acc3 += a * W[(j + 3) * 32 + k];
      }
      acc0 += B[j + 0];
      acc1 += B[j + 1];
      acc2 += B[j + 2];
      acc3 += B[j + 3];
      Out[i * 64 + j + 0] = Math.max(acc0, 0);
      Out[i * 64 + j + 1] = Math.max(acc1, 0);
      Out[i * 64 + j + 2] = Math.max(acc2, 0);
      Out[i * 64 + j + 3] = Math.max(acc3, 0);
    }
  }
}

function fused_dense_bias_reg4(A, W, B, Out) {
  // Register-tiled: 4-way accumulator unrolling
  // Loads A[k] once, reuses for 4 output elements → 4× fewer A reads
  for (let i = 0; i < 1; i++) {
    for (let j = 0; j < 8; j += 4) {
      let acc0 = acc1 = acc2 = acc3 = 0;
      for (let k = 0; k < 64; k++) {
        const a = A[i * 64 + k]; // load once, reuse 4x
        acc0 += a * W[(j + 0) * 64 + k];
        acc1 += a * W[(j + 1) * 64 + k];
        acc2 += a * W[(j + 2) * 64 + k];
        acc3 += a * W[(j + 3) * 64 + k];
      }
      acc0 += B[j + 0];
      acc1 += B[j + 1];
      acc2 += B[j + 2];
      acc3 += B[j + 3];
      Out[i * 8 + j + 0] = acc0;
      Out[i * 8 + j + 1] = acc1;
      Out[i * 8 + j + 2] = acc2;
      Out[i * 8 + j + 3] = acc3;
    }
  }
}


