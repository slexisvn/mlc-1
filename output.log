          }
        }
        acc = (acc + B[0 * 64 + ((j_outer * 8) + j_inner)]);
        Out[i * 64 + ((j_outer * 8) + j_inner)] = Math.max(acc, 0);
      }
      { const j_inner = 5;
        acc = 0;
        for (let k_outer = 0; k_outer < 8; k_outer++) {
          for (let k_inner = 0; k_inner < 4; k_inner++) {
            acc = (acc + (A[i * 32 + ((k_outer * 4) + k_inner)] * W[((j_outer * 8) + j_inner) * 32 + ((k_outer * 4) + k_inner)]));
