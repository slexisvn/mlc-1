  Phase 4: Operator Lowering (→ TensorIR / Loop Nests)
════════════════════════════════════════════════════════════
  Lowered 2 PrimFunc(s):

@fused_dense_bias_relu(A: Buffer[1,784], W: Buffer[256,784], B: Buffer[1,256], Out: Buffer[1,256]) {
  alloc acc: float32[1]  scope=local
  for i in range(0, 1):
    for j in range(0, 256):
      acc[0] = 0
      for k in range(0, 784):  // reduction
        acc[0] = (acc[0] + (A[i, k] * W[j, k]))
      acc[0] = (acc[0] + B[0, j])
      Out[i, j] = max(acc[0], 0)
}

@fused_dense_bias(A: Buffer[1,256], W: Buffer[10,256], B: Buffer[1,10], Out: Buffer[1,10]) {
  alloc acc: float32[1]  scope=local
  for i in range(0, 1):
    for j in range(0, 10):
      acc[0] = 0
      for k in range(0, 256):  // reduction
        acc[0] = (acc[0] + (A[i, k] * W[j, k]))
      acc[0] = (acc[0] + B[0, j])
      Out[i, j] = acc[0]
}


