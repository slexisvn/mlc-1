  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 1; i++) {
    for (let j = 0; j < 10; j++) {
      acc[0] = 0;
      for (let k = 0; k < 256; k++) {
        acc[0] = (acc[0] + (A[i * 256 + k] * W[j * 256 + k]));
      }
      acc[0] = (acc[0] + B[0 * 10 + j]);
      Out[i * 10 + j] = acc[0];
    }
  }
}


