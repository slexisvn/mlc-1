    Created: acc_rf[4]  ← partial sum buffer
    Phase 1 (parallel): each k_outer writes acc_rf[k_outer]
    Phase 2 (merge):    sum acc_rf[0..4) into acc[0]

  rfactor TIR:
@fused_dense_bias_relu(A: Buffer[4,32], W: Buffer[64,32], B: Buffer[1,64], Out: Buffer[4,64]) {
  alloc acc: float32[1]  scope=local
  alloc acc_rf: float32[4]  scope=local
  for i in range(0, 4):
    for j in range(0, 64):
      acc[0] = 0
      for k_outer in range(0, 4):  // parallel  // reduction
        acc_rf[k_outer] = 0
        for k_inner in range(0, 8):  // reduction
          acc_rf[k_outer] = (acc_rf[k_outer] + (A[i, ((k_outer * 8) + k_inner)] * W[j, ((k_outer * 8) + k_inner)]))
      acc[0] = 0
      for k_outer_merge in range(0, 4):  // reduction
        acc[0] = (acc[0] + acc_rf[k_outer_merge])
      acc[0] = (acc[0] + B[0, j])
      Out[i, j] = max(acc[0], 0)
}

