function fused_dense_bias(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 64] (global)
  // W: [8, 64] (global)
  // B: [1, 8] (global)
  // Out: [4, 8] (global)
  
  let acc = 0; // scalar (promoted from buffer)
  
  for (let i = 0; i < 4; i++) {
    for (let j = 0; j < 8; j++) {
      acc = 0;
      for (let k = 0; k < 64; k++) {
        acc = (acc + (A[i * 64 + k] * W[j * 64 + k]));
