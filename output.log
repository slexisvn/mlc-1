function fused_dense_bias_sigmoid(A, W, B, Out) {
  // Buffer shapes:
  // A: [1, 784] (global)
  // W: [256, 784] (global)
  // B: [1, 256] (global)
  // Out: [1, 256] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 1; i++) {
    for (let j = 0; j < 256; j++) {
      acc[0] = 0;
      for (let k = 0; k < 784; k++) {
        acc[0] = (acc[0] + (A[i * 784 + k] * W[j * 784 + k]));
      }
      acc[0] = (acc[0] + B[0 * 256 + j]);
      Out[i * 256 + j] = (1 / (1 + Math.exp((0 - acc[0]))));
    }
  }
}

