  Scheduled TIR:
@fused_dense_bias_relu(A: Buffer[4,32], W: Buffer[64,32], B: Buffer[1,64], Out: Buffer[4,64]) {
  alloc acc: float32[1]  scope=local
  alloc W_local: float32[32,32]  scope=local
  for i in range(0, 4):
    for j_outer in range(0, 2):  // parallel
      for _jl_cr in range(0, 32):
        for _kl_cr in range(0, 32):
          W_local[_jl_cr, _kl_cr] = W[((j_outer * 32) + _jl_cr), _kl_cr]
      for j_inner in range(0, 32):
        acc[0] = 0
        for k in range(0, 32):  // reduction
          acc[0] = (acc[0] + (A[i, k] * W_local[j_inner, k]))
        acc[0] = (acc[0] + B[0, ((j_outer * 32) + j_inner)])
        Out[i, ((j_outer * 32) + j_inner)] = max(acc[0], 0)
}

@fused_dense_bias(A: Buffer[4,64], W: Buffer[8,64], B: Buffer[1,8], Out: Buffer[4,8]) {
  alloc acc: float32[1]  scope=local
  for i in range(0, 4):
    for j in range(0, 8):
      acc[0] = 0
      for k in range(0, 64):  // reduction
        acc[0] = (acc[0] + (A[i, k] * W[j, k]))
      acc[0] = (acc[0] + B[0, j])
      Out[i, j] = acc[0]
}


