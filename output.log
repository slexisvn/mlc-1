function fused_dense_bias_relu(A, W, B, Out) {
  // Buffer shapes:
  // A: [1, 784] (global)
  // W: [256, 784] (global)
  // B: [1, 256] (global)
  // Out: [1, 256] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 1; i++) {
    for (let j = 0; j < 256; j++) {
      acc[0] = 0;
      for (let k = 0; k < 784; k++) {
        acc[0] = (acc[0] + (A[i * 784 + k] * W[j * 784 + k]));
      }
      acc[0] = (acc[0] + B[0 * 256 + j]);
      Out[i * 256 + j] = Math.max(acc[0], 0);
    }
  }
}

function fused_dense_bias(A, W, B, Out) {
  // Buffer shapes:
  // A: [1, 256] (global)
  // W: [10, 256] (global)
  // B: [1, 10] (global)
  // Out: [1, 10] (global)
  
  const acc = new Float32Array(1); // local
  
  for (let i = 0; i < 1; i++) {
    for (let j = 0; j < 10; j++) {
      acc[0] = 0;
      for (let k = 0; k < 256; k++) {
        acc[0] = (acc[0] + (A[i * 256 + k] * W[j * 256 + k]));
      }
      acc[0] = (acc[0] + B[0 * 10 + j]);
      Out[i * 10 + j] = acc[0];
    }
  }
}


── Scheduled (optimized) code ──
function fused_dense_bias_relu(A, W, B, Out) {
  // Buffer shapes:
  // A: [1, 784] (global)
  // W: [256, 784] (global)
  // B: [1, 256] (global)
