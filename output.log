          }
        }
        acc[0] = (acc[0] + B[0 * 256 + ((j_outer * 32) + j_inner)]);
        Out[i * 256 + ((j_outer * 32) + j_inner)] = Math.max(acc[0], 0);
      }
    }
  }
}

function fused_dense_bias(A, W, B, Out) {
  // Buffer shapes:
  // A: [1, 256] (global)
  // W: [10, 256] (global)
  // B: [1, 10] (global)
