── 7.1 Tuner-selected TIR → feeds Phase 8 & Phase 9 ──
@fused_dense_bias_relu(A: Buffer[4,32], W: Buffer[64,32], B: Buffer[1,64], Out: Buffer[4,64]) {
  alloc acc: float32[1]  scope=local
  for i_outer in range(0, 1):
    for j_outer in range(0, 8):
      for i_inner in range(0, 4):
        for j_inner in range(0, 8):  // unroll
          acc[0] = 0
          for k_outer in range(0, 8):  // reduction
            for k_inner in range(0, 4):  // reduction
              acc[0] = (acc[0] + (A[((i_outer * 4) + i_inner), ((k_outer * 4) + k_inner)] * W[((j_outer * 8) + j_inner), ((k_outer * 4) + k_inner)]))
          acc[0] = (acc[0] + B[0, ((j_outer * 8) + j_inner)])
          Out[((i_outer * 4) + i_inner), ((j_outer * 8) + j_inner)] = max(acc[0], 0)
}

@fused_dense_bias(A: Buffer[4,64], W: Buffer[8,64], B: Buffer[1,8], Out: Buffer[4,8]) {
  alloc acc: float32[1]  scope=local
  for i in range(0, 4):
    for j in range(0, 8):
      acc[0] = 0
      for k in range(0, 64):  // reduction
        acc[0] = (acc[0] + (A[i, k] * W[j, k]))
      acc[0] = (acc[0] + B[0, j])
      Out[i, j] = acc[0]
}


