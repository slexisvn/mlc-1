── Scheduled + Optimized code (tuner-selected schedule) ──
function fused_dense_bias_relu_packed(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 32] (global)
  // W: [64, 32] (global)
  // B: [1, 64] (global)
  // Out: [4, 64] (global)
  
  const W_packed = new Float32Array(2048); // local
  let acc = 0; // scalar (promoted from buffer)
  
  for (let _jo_pack = 0; _jo_pack < 4; _jo_pack++) {
    for (let _kl_pack = 0; _kl_pack < 32; _kl_pack++) {
      for (let _ji_pack = 0; _ji_pack < 16; _ji_pack++) {
        W_packed[_jo_pack * 512 + _kl_pack * 16 + _ji_pack] = W[((_jo_pack * 16) + _ji_pack) * 32 + _kl_pack];
      }
    }
  }
  for (let i_outer = 0; i_outer < 1; i_outer++) {
    for (let j_outer = 0; j_outer < 32; j_outer++) {
      for (let i_inner = 0; i_inner < 4; i_inner++) {
        // unrolled loop j_inner (2 iterations)
        { const j_inner = 0;
          acc = 0;
          for (let k_outer = 0; k_outer < 8; k_outer++) {
            for (let k_inner = 0; k_inner < 4; k_inner++) {
              acc = (acc + (A[((i_outer * 4) + i_inner) * 32 + ((k_outer * 4) + k_inner)] * W_packed[Math.floor(((j_outer * 2) + j_inner) / 16) * 512 + ((k_outer * 4) + k_inner) * 16 + (((j_outer * 2) + j_inner) % 16)]));
            }
          }
          acc = (acc + B[0 * 64 + ((j_outer * 2) + j_inner)]);
          Out[((i_outer * 4) + i_inner) * 64 + ((j_outer * 2) + j_inner)] = Math.max(acc, 0);
        }
        { const j_inner = 1;
          acc = 0;
          for (let k_outer = 0; k_outer < 8; k_outer++) {
            for (let k_inner = 0; k_inner < 4; k_inner++) {
              acc = (acc + (A[((i_outer * 4) + i_inner) * 32 + ((k_outer * 4) + k_inner)] * W_packed[Math.floor(((j_outer * 2) + j_inner) / 16) * 512 + ((k_outer * 4) + k_inner) * 16 + (((j_outer * 2) + j_inner) % 16)]));
            }
          }
          acc = (acc + B[0 * 64 + ((j_outer * 2) + j_inner)]);
          Out[((i_outer * 4) + i_inner) * 64 + ((j_outer * 2) + j_inner)] = Math.max(acc, 0);
        }
      }
    }
  }
}

function fused_dense_bias(A, W, B, Out) {
  // Buffer shapes:
  // A: [4, 64] (global)
  // W: [8, 64] (global)
  // B: [1, 8] (global)
  // Out: [4, 8] (global)
  
  let acc = 0; // scalar (promoted from buffer)
  
  for (let i_outer = 0; i_outer < 2; i_outer++) {
    for (let j_outer = 0; j_outer < 8; j_outer++) {
      for (let i_inner = 0; i_inner < 2; i_inner++) {
        for (let j_inner = 0; j_inner < 1; j_inner++) {
          acc = 0;
          for (let k_outer = 0; k_outer < 2; k_outer++) {
            for (let k_inner = 0; k_inner < 32; k_inner++) {
              acc = (acc + (A[((i_outer * 2) + i_inner) * 64 + ((k_outer * 32) + k_inner)] * W[(j_outer + j_inner) * 64 + ((k_outer * 32) + k_inner)]));
            }
          }
          acc = (acc + B[0 * 8 + (j_outer + j_inner)]);
          Out[((i_outer * 2) + i_inner) * 8 + (j_outer + j_inner)] = acc;
        }
      }
    }
  }
}


── 8.2 Register-Tiled code (4-way accumulator) ──
function fused_dense_bias_relu_reg4(A, W, B, Out) {
  // Register-tiled: 4-way accumulator unrolling
  // Loads A[k] once, reuses for 4 output elements → 4× fewer A reads
  for (let i = 0; i < 4; i++) {
    for (let j = 0; j < 64; j += 4) {
      let acc0 = 0, acc1 = 0, acc2 = 0, acc3 = 0;
      for (let k = 0; k < 32; k++) {
        const a = A[i * 32 + k]; // load once, reuse 4x
        acc0 += a * W[(j + 0) * 32 + k];
        acc1 += a * W[(j + 1) * 32 + k];
        acc2 += a * W[(j + 2) * 32 + k];
        acc3 += a * W[(j + 3) * 32 + k];
      }
      acc0 += B[j + 0];
      acc1 += B[j + 1];
      acc2 += B[j + 2];
      acc3 += B[j + 3];
      Out[i * 64 + j + 0] = Math.max(acc0, 0);
      Out[i * 64 + j + 1] = Math.max(acc1, 0);
      Out[i * 64 + j + 2] = Math.max(acc2, 0);
      Out[i * 64 + j + 3] = Math.max(acc3, 0);
    }
  }
}

function fused_dense_bias_reg4(A, W, B, Out) {
  // Register-tiled: 4-way accumulator unrolling
  // Loads A[k] once, reuses for 4 output elements → 4× fewer A reads
  for (let i = 0; i < 4; i++) {
    for (let j = 0; j < 8; j += 4) {
      let acc0 = 0, acc1 = 0, acc2 = 0, acc3 = 0;
      for (let k = 0; k < 64; k++) {
        const a = A[i * 64 + k]; // load once, reuse 4x
        acc0 += a * W[(j + 0) * 64 + k];
        acc1 += a * W[(j + 1) * 64 + k];
        acc2 += a * W[(j + 2) * 64 + k];
        acc3 += a * W[(j + 3) * 64 + k];
      }
      acc0 += B[j + 0];
      acc1 += B[j + 1];
      acc2 += B[j + 2];
      acc3 += B[j + 3];
      Out[i * 8 + j + 0] = acc0;
      Out[i * 8 + j + 1] = acc1;
      Out[i * 8 + j + 2] = acc2;
      Out[i * 8 + j + 3] = acc3;
    }
  }
}


